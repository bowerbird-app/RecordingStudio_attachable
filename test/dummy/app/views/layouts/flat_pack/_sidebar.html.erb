<%= render FlatPack::Sidebar::Component.new(side: sidebar_side) do |sidebar| %>
  <% sidebar.header do %>
    <%= render FlatPack::Sidebar::Header::Component.new(
      brand_abbr: "RS",
      title: "Attachable",
      subtitle: "Recording Studio"
    ) %>
  <% end %>

  <% sidebar.items do %>
    <nav class="py-4 space-y-1" aria-label="Main navigation">
      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Home",
        href: "/",
        icon: :home
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Setup",
        href: setup_docs_path,
        icon: :folder
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Config",
        href: configuration_docs_path,
        icon: :settings
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Methods",
        href: methods_docs_path,
        icon: :folder
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Plugins",
        href: plugins_docs_path,
        icon: :box
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Resizing",
        href: resizing_docs_path,
        icon: :image
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Gem views",
        href: gem_views_docs_path,
        icon: :file
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Recordables",
        href: recordables_docs_path,
        icon: :folder
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Query",
        href: query_docs_path,
        icon: :file
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Recording tree",
        href: recording_tree_path,
        icon: :folder
      ) %>
    </nav>
  <% end %>

  <% sidebar.footer do %>
    <%= render FlatPack::Sidebar::Footer::Component.new(class: "text-sm text-[var(--surface-muted-content-color)]") do %>
      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Sign out",
        href: destroy_user_session_path,
        icon: :lock,
        class: "mx-0",
        data: { turbo_method: :delete }
      ) %>
    <% end %>
  <% end %>
<% end %>
