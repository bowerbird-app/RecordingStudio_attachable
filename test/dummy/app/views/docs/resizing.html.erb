<div class="mx-auto flex w-full max-w-4xl flex-col gap-8">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Resizing",
    subtitle: "Configure browser-side image resizing before direct upload for the dummy app and the engine's built-in upload flows.",
    variant: :h1
  ) %>

  <section class="space-y-3">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Browser side resezing",
      subtitle: "You can set a max size and get the browser to resize oversized JPEG, PNG, and WebP uploads before they are sent to Active Storage, including extra downscaling when the file still needs to fit the byte limit.",
      anchor_link: true
    ) %>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "config/initializers/recording_studio_attachable.rb",
      code: @resizing_config_example,
      language: :ruby
    ) %>
  </section>

  <section class="space-y-3">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Size variants",
      subtitle: "Summarise how they work",
      anchor_link: true
    ) %>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "config/initializers/recording_studio_attachable.rb",
      code: @variant_config_example,
      language: :ruby
    ) %>
  </section>
</div>