<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <% parent_recordable = @recording.recordable %>
  <% parent_recordable_name =
       if parent_recordable.respond_to?(:title) && parent_recordable.title.present?
         parent_recordable.title
       elsif parent_recordable.respond_to?(:name) && parent_recordable.name.present?
         parent_recordable.name
       elsif parent_recordable.respond_to?(:email) && parent_recordable.email.present?
         parent_recordable.email
       else
         @recording.recordable_type.demodulize
       end %>

  <%= render FlatPack::Breadcrumb::Component.new(
    show_back: true,
    back_text: "Back",
    back_icon: "arrow-left",
    back_href: request.referer.presence || "javascript:history.back()",
    items: [{ text: "Home", href: main_app.root_path, icon: "home" }]
  ) %>

  <%= render FlatPack::PageTitle::Component.new(
    title: "Library",
    subtitle: parent_recordable_name,
    variant: :h1
  ) %>

  <% listing_params = {
       scope: @scope,
       kind: @kind,
       q: @query,
       include_trashed: @include_trashed.presence,
       view: @view_mode
     }.compact %>

  <%= turbo_frame_tag "recording-attachments-results" do %>
    <div class="space-y-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="flex flex-wrap items-center gap-3">
          <% if @can_upload %>
            <%= link_to recording_attachment_upload_path(@recording), class: "inline-flex", data: { turbo_frame: "_top" } do %>
              <%= render FlatPack::Button::Component.new(text: "Upload", style: :primary, size: :md, icon: "upload") %>
            <% end %>
          <% end %>

          <div class="flex items-center gap-2">
            <%= link_to recording_attachments_path(@recording, listing_params.merge(view: :grid)), class: "inline-flex", data: { turbo_frame: "recording-attachments-results", turbo_action: "advance" } do %>
              <%= render FlatPack::Button::Component.new(icon: "squares-2x2", icon_only: true, style: (@view_mode == :grid ? :secondary : :ghost), size: :md, aria: { label: "Grid view" }) %>
            <% end %>
            <%= link_to recording_attachments_path(@recording, listing_params.merge(view: :list)), class: "inline-flex", data: { turbo_frame: "recording-attachments-results", turbo_action: "advance" } do %>
              <%= render FlatPack::Button::Component.new(icon: "list-bullet", icon_only: true, style: (@view_mode == :list ? :secondary : :ghost), size: :md, aria: { label: "List view" }) %>
            <% end %>
          </div>
        </div>

        <%= form_with url: recording_attachments_path(@recording), method: :get, local: true, class: "w-full lg:w-auto", data: { controller: "recording-studio-attachable--live-search", action: "input->recording-studio-attachable--live-search#queueSubmit", turbo_frame: "recording-attachments-results", turbo_action: "advance" } do %>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
            <%= hidden_field_tag :scope, @scope %>
            <%= hidden_field_tag :kind, @kind %>
            <%= hidden_field_tag :view, @view_mode %>
            <%= hidden_field_tag :include_trashed, @include_trashed if @include_trashed %>
            <%= render FlatPack::Search::Component.new(
              name: :q,
              value: @query,
              placeholder: "Search",
              max_width: :lg,
              aria: { label: "Search attachments" }
            ) %>
          </div>
        <% end %>
      </div>

      <% if @attachments.any? %>
        <% if @view_mode == :grid %>
          <%= render "grid", attachments: @attachments %>
        <% else %>
          <%= render "list", attachments: @attachments %>
        <% end %>

        <% if @total_pages > 1 %>
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="text-sm text-(--surface-muted-content-color)">
              Showing page <%= @page %> of <%= @total_pages %>
            </div>
            <div class="flex gap-3">
              <% if @page > 1 %>
                <%= link_to recording_attachments_path(@recording, listing_params.merge(page: @page - 1)), class: "inline-flex", data: { turbo_frame: "recording-attachments-results", turbo_action: "advance" } do %>
                  <%= render FlatPack::Button::Component.new(text: "Previous", style: :secondary, size: :md) %>
                <% end %>
              <% end %>
              <% if @page < @total_pages %>
                <%= link_to recording_attachments_path(@recording, listing_params.merge(page: @page + 1)), class: "inline-flex", data: { turbo_frame: "recording-attachments-results", turbo_action: "advance" } do %>
                  <%= render FlatPack::Button::Component.new(text: "Next", style: :secondary, size: :md) %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
          <% card.body do %>
            <div class="flex flex-col items-center justify-center gap-4 px-6 py-12 text-center">
              <div class="flex h-16 w-16 items-center justify-center rounded-full bg-(--surface-muted-background-color) text-(--surface-muted-content-color)">
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m21 21-4.35-4.35" />
                  <circle cx="11" cy="11" r="6" />
                </svg>
              </div>
              <%= render FlatPack::PageTitle::Component.new(
                title: @query.present? ? "Nothing found" : "Nothing uplaoded yet",
                subtitle: @query.present? ? nil : "Upload files to start building this library.",
                variant: :h3,
                class: "mb-0 pb-0"
              ) %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
</div>
