<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <%= render FlatPack::Breadcrumb::Component.new(
    show_back: true,
    back_text: "Back",
    back_icon: "arrow-left",
    back_href: request.referer.presence || main_app.root_path,
    items: [{ text: "Home", href: main_app.root_path, icon: "home" }]
  ) %>

  <%= render FlatPack::PageTitle::Component.new(
    title: @attachment.name,
    subtitle: @attachment.original_filename,
    variant: :h1
  ) %>

  <div class="flex flex-wrap gap-3">
    <%= link_to "#edit-attachment", class: "inline-flex" do %>
      <%= render FlatPack::Button::Component.new(text: "Edit", style: :primary, size: :md) %>
    <% end %>

    <% unless @attachment_recording.respond_to?(:trashed_at) && @attachment_recording.trashed_at.present? %>
      <%= button_to destroy_attachment_path(@attachment_recording), method: :delete, class: "inline-flex" do %>
        <%= render FlatPack::Button::Component.new(text: "Trash", style: :secondary, size: :md) %>
      <% end %>
    <% end %>
  </div>

  <% preview_path = authorized_attachment_preview_path(@attachment_recording, :large) %>
  <% if preview_path.present? %>
    <%= image_tag preview_path, alt: @attachment.name, class: "max-h-[480px] w-full object-contain" %>
  <% end %>

  <%= render FlatPack::Card::Component.new(style: :outlined, html_options: { id: "edit-attachment" }) do |card| %>
    <% card.header do %>
      <%= render FlatPack::PageTitle::Component.new(
        title: "Edit attachment",
        subtitle: "Update the attachment metadata or replace the file.",
        variant: :h3,
        class: "mb-0 pb-0"
      ) %>
    <% end %>

    <% card.body do %>
      <%= form_with model: @attachment, url: attachment_path(@attachment_recording), method: :patch, class: "space-y-4" do |form| %>
        <div class="space-y-4">
          <%= render FlatPack::TextInput::Component.new(name: "attachment[name]", label: "Name", value: @attachment.name, required: true) %>

          <div>
            <label class="mb-2 block text-sm font-medium">Description</label>
            <%= form.text_area :description,
                               name: "attachment[description]",
                               value: @attachment.description,
                               class: "min-h-24 w-full rounded-lg border border-[var(--surface-border-color)] bg-transparent px-3 py-2" %>
          </div>

          <div class="space-y-2">
            <label class="block text-sm font-medium" for="attachment_signed_blob_id">Replace file (optional)</label>
            <%= file_field_tag "attachment[signed_blob_id]",
                               direct_upload: true,
                               accept: @replace_allowed_content_types.join(","),
                               class: "block w-full rounded-lg border border-[var(--surface-border-color)] bg-transparent px-3 py-2" %>
            <p class="text-xs text-(--surface-muted-content-color)">
              Allowed types: <%= @replace_allowed_content_types.join(", ") %> · Max size: <%= number_to_human_size(@replace_max_file_size) %>
            </p>
          </div>
        </div>

        <%= render FlatPack::Button::Component.new(text: "Save revision", style: :primary, size: :md, type: "submit") %>
      <% end %>
    <% end %>
  <% end %>
</div>
