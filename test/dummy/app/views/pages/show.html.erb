<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <%= render FlatPack::Breadcrumb::Component.new(
    show_back: true,
    back_text: "Back",
    back_icon: "arrow-left",
    back_href: request.referer.presence || root_path,
    items: [{ text: "Home", href: root_path, icon: "home" }]
  ) %>

  <%= render FlatPack::PageTitle::Component.new(
    title: @page.title,
    subtitle: "Review the inline page content and related page actions.",
    variant: :h1
  ) %>

  <div class="flex flex-wrap gap-3">
    <%= link_to edit_page_path(@page), class: "inline-flex" do %>
      <%= render FlatPack::Button::Component.new(text: "Edit inline", style: :primary, size: :md) %>
    <% end %>
  </div>

  <div class="prose max-w-none text-(--surface-content-color)">
    <%= sanitize(
      @page.body.presence || "<p>No page content yet.</p>",
      tags: %w[p br strong em u s code blockquote ul ol li h1 h2 h3 a img figure figcaption],
      attributes: %w[href src alt title]
    ) %>
  </div>
</div>