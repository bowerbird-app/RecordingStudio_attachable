<div class="mx-auto flex w-full max-w-4xl flex-col gap-8">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Attachment demo",
    subtitle: "Workspace uploads accept images and files. Page uploads accept images only.",
    variant: :h1
  ) %>

  <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
    <% card.body do %>
      <div class="space-y-4">
        <%= render FlatPack::SectionTitle::Component.new(
          title: "Workspace",
          subtitle: "Upload images, PDFs, and text files to the workspace library.",
          anchor_link: true
        ) %>

        <% if @root_attachment_upload_path.present? && @root_attachment_listing_path.present? %>
          <div class="flex flex-wrap gap-3">
            <%= link_to @root_attachment_upload_path, class: "inline-flex" do %>
              <%= render FlatPack::Button::Component.new(text: "Add", style: :primary, size: :md) %>
            <% end %>
            <%= link_to @root_attachment_listing_path, class: "inline-flex" do %>
              <%= render FlatPack::Button::Component.new(text: "Library", style: :secondary, size: :md) %>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-(--surface-muted-content-color)">Seed the workspace recording to enable the demo links.</p>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <section>
    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.body do %>
        <div class="space-y-4">
          <%= render FlatPack::SectionTitle::Component.new(
            title: "Page",
            subtitle: "Add images below page recording",
            anchor_link: true
          ) %>

          <% if @page_attachment_upload_path.present? && @page_attachment_listing_path.present? %>
            <div class="flex flex-wrap gap-3">
              <%= link_to @page_attachment_upload_path, class: "inline-flex" do %>
                <%= render FlatPack::Button::Component.new(text: "Add", style: :primary, size: :md) %>
              <% end %>
              <%= link_to @page_attachment_listing_path, class: "inline-flex" do %>
                <%= render FlatPack::Button::Component.new(text: "Page library", style: :secondary, size: :md) %>
              <% end %>
              <%= link_to @page_show_path, class: "inline-flex" do %>
                <%= render FlatPack::Button::Component.new(text: "View", style: :secondary, size: :md) %>
              <% end %>
              <%= link_to @page_edit_path, class: "inline-flex" do %>
                <%= render FlatPack::Button::Component.new(text: "Edit inline", style: :secondary, size: :md) %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-(--surface-muted-content-color)">Seed the page recording to enable the page attachment demo.</p>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </section>
</div>
