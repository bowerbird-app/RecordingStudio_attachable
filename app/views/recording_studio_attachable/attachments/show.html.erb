<div class="mx-auto flex w-full max-w-6xl flex-col gap-6 px-6">
  <%= render FlatPack::Breadcrumb::Component.new(
    show_back: true,
    back_text: "Back",
    back_icon: "arrow-left",
    back_href: request.referer.presence || main_app.root_path,
    items: [{ text: "Home", href: main_app.root_path, icon: "home" }]
  ) %>

  <%= render FlatPack::PageTitle::Component.new(
    title: @attachment.name,
    subtitle: @attachment.original_filename,
    variant: :h1
  ) %>

  <div class="flex flex-wrap gap-3">
    <%= render FlatPack::Tooltip::Component.new(text: "Download") do %>
      <%= render FlatPack::Button::Component.new(
        icon: "arrow-down-tray",
        icon_only: true,
        style: :secondary,
        size: :md,
        aria: { label: "Download attachment" },
        url: download_attachment_path(@attachment_recording),
        data: { turbo_frame: "_top" }
      ) %>
    <% end %>

    <% unless @attachment_recording.respond_to?(:trashed_at) && @attachment_recording.trashed_at.present? %>
      <%= render FlatPack::Tooltip::Component.new(text: "Trash") do %>
        <%= button_to destroy_attachment_path(@attachment_recording), method: :delete, class: "inline-flex" do %>
          <%= render FlatPack::Button::Component.new(icon: "trash", icon_only: true, style: :secondary, size: :md, aria: { label: "Trash attachment" }) %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <div class="grid gap-6 lg:grid-cols-2 lg:items-start">
    <% preview_path = authorized_attachment_preview_path(@attachment_recording, :large) %>
    <% file_extension = File.extname(@attachment.original_filename.to_s).delete(".").upcase.presence || "FILE" %>

    <div class="space-y-4">
      <% if preview_path.present? %>
        <div class="overflow-hidden rounded-xl border border-(--surface-border-color) bg-(--surface-muted-background-color)">
          <div class="relative aspect-square" data-controller="recording-studio-attachable--image-fallback">
            <div class="absolute inset-0 flex items-stretch justify-stretch" data-recording-studio-attachable--image-fallback-target="skeleton">
              <%= render FlatPack::Skeleton::Component.new(variant: :rectangle, shimmer: true, width: "100%", height: "100%", class: "h-full w-full rounded-none") %>
            </div>
            <%= image_tag preview_path, alt: @attachment.name, class: "h-full w-full object-cover opacity-0 transition-opacity duration-200", data: { recording_studio_attachable__image_fallback_target: "image", action: "load->recording-studio-attachable--image-fallback#showImage error->recording-studio-attachable--image-fallback#showFallback" } %>
            <div class="absolute inset-0 hidden items-center justify-center bg-(--surface-background-color)" data-recording-studio-attachable--image-fallback-target="fallback">
              <div class="flex flex-col items-center justify-center gap-3 px-4 text-center">
                <div class="flex h-16 w-16 items-center justify-center rounded-full bg-(--surface-background-color) text-(--surface-content-color) shadow-sm ring-1 ring-(--surface-border-color)">
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 9v4" />
                    <path d="M12 17h.01" />
                    <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
                  </svg>
                </div>
                <span class="text-xs font-semibold uppercase tracking-[0.18em] text-(--surface-muted-content-color)">IMAGE</span>
                <span class="text-sm text-(--surface-muted-content-color)">Preview unavailable</span>
              </div>
            </div>
          </div>
        </div>
      <% else %>
        <div class="flex aspect-square items-center justify-center rounded-xl border border-(--surface-border-color) bg-(--surface-background-color)">
          <div class="flex flex-col items-center justify-center gap-3 px-4 text-center">
            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-(--surface-background-color) text-(--surface-content-color) shadow-sm ring-1 ring-(--surface-border-color)">
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.25 3.75H7.5A2.25 2.25 0 0 0 5.25 6v12A2.25 2.25 0 0 0 7.5 20.25h9A2.25 2.25 0 0 0 18.75 18V8.25l-4.5-4.5Z" />
                <path d="M14.25 3.75V8.25h4.5" />
                <path d="M9 12.75h6" />
                <path d="M9 16.5h6" />
              </svg>
            </div>
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-(--surface-muted-content-color)"><%= file_extension %></span>
          </div>
        </div>
      <% end %>
    </div>

    <div id="edit-attachment" class="space-y-4 lg:col-start-2">
      <%= form_with model: @attachment, url: attachment_path(@attachment_recording), method: :patch, class: "space-y-4" do |form| %>
        <div class="space-y-4">
          <%= render FlatPack::TextInput::Component.new(name: "attachment[name]", label: "Name", value: @attachment.name, required: true) %>

          <div>
            <label class="mb-2 block text-sm font-medium">Description</label>
            <%= form.text_area :description,
                               name: "attachment[description]",
                               value: @attachment.description,
                               class: "min-h-24 w-full rounded-lg border border-[var(--surface-border-color)] bg-transparent px-3 py-2" %>
          </div>
        </div>

        <%= render FlatPack::Button::Component.new(text: "Save", style: :primary, size: :md, type: "submit") %>
      <% end %>
    </div>
  </div>
</div>
