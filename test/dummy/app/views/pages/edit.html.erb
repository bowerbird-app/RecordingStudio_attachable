<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <%= render FlatPack::Breadcrumb::Component.new(
    show_back: true,
    back_text: "Back",
    back_icon: "arrow-left",
    back_href: request.referer.presence || root_path,
    items: [{ text: "Home", href: root_path, icon: "home" }]
  ) %>

  <%= render FlatPack::PageTitle::Component.new(
    title: "Edit inline",
    subtitle: "Update page copy and formatted content for the inline recording demo.",
    variant: :h1
  ) %>

  <div class="flex flex-wrap gap-3">
    <%= render FlatPack::Button::Component.new(text: "View", style: :secondary, size: :md, url: page_path(@page)) %>
  </div>

  <%= form_with model: @page, class: "space-y-4" do %>
    <%= render FlatPack::TextInput::Component.new(
      name: "page[title]",
      label: "Page title",
      value: @page.title,
      required: true
    ) %>

    <% editor_modal_id = "page-image-picker-modal-#{@page.id}" %>
    <% html_preview_modal_id = "page-html-preview-modal-#{@page.id}" %>
    <% body_field = capture do %>
      <%= render FlatPack::TextArea::Component.new(
        name: "page[body]",
        label: "Body",
        value: @page.body,
        placeholder: "Write the page content here...",
        rich_text: true,
        rich_text_options: {
          preset: :content,
          addons: [{ name: :attachment_image }, { name: :html_preview }],
          toolbar: [
            "bold",
            "italic",
            "underline",
            "sep1",
            "strike",
            "code",
            "sep2",
            "attachmentImage",
            "htmlPreview",
            "h1",
            "h2",
            "h3",
            "sep3",
            "bulletList",
            "orderedList",
            "sep4",
            "blockquote",
            "sep5",
            "undo",
            "redo"
          ],
          bubble_menu: false,
          floating_menu: false
        },
        required: true
      ) %>
    <% end %>

    <div
      data-controller="page-html-preview"
      data-action="flat-pack:html-preview->page-html-preview#openFromToolbar"
      data-page-html-preview-modal-id-value="<%= html_preview_modal_id %>">
      <% if @page_recording.present? %>
        <div
          data-controller="recording-studio-attachable--attachment-image-picker"
          data-action="recording-studio-inline-picker->recording-studio-attachable--attachment-image-picker#openPickerFromToolbar"
          data-recording-studio-attachable--attachment-image-picker-picker-url-value="<%= @page_attachment_picker_path %>"
          data-recording-studio-attachable--attachment-image-picker-upload-url-value="<%= @page_attachment_create_path %>"
          data-recording-studio-attachable--attachment-image-picker-direct-upload-url-value="<%= main_app.rails_direct_uploads_path %>"
          data-recording-studio-attachable--attachment-image-picker-max-file-size-value="<%= RecordingStudioAttachable.configuration.max_file_size %>"
          data-recording-studio-attachable--attachment-image-picker-image-processing-enabled-value="<%= RecordingStudioAttachable.configuration.image_processing_enabled %>"
          data-recording-studio-attachable--attachment-image-picker-image-processing-max-width-value="<%= RecordingStudioAttachable.configuration.image_processing_max_width %>"
          data-recording-studio-attachable--attachment-image-picker-image-processing-max-height-value="<%= RecordingStudioAttachable.configuration.image_processing_max_height %>"
          data-recording-studio-attachable--attachment-image-picker-image-processing-quality-value="<%= RecordingStudioAttachable.configuration.image_processing_quality %>"
          data-recording-studio-attachable--attachment-image-picker-modal-id-value="<%= editor_modal_id %>">
          <div data-recording-studio-attachable--attachment-image-picker-target="editorHost">
            <%= body_field %>
          </div>

          <%= render FlatPack::Modal::Component.new(id: editor_modal_id, title: "Insert image", size: :xl, body_height_mode: :fixed, body_height: "32rem") do |modal| %>
            <% modal.body do %>
              <% cloud_upload_providers = RecordingStudioAttachable.configuration.upload_providers.select do |provider|
                   provider.render?(view_context: self, recording: @page_recording) && provider.client_picker?
                 end %>

              <div class="flex h-full min-h-0 flex-col gap-4">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                  <div class="flex flex-wrap items-center gap-3">
                    <%= render FlatPack::Button::Dropdown::Component.new(text: "Upload", style: :primary, size: :md) do |dropdown| %>
                      <% dropdown.menu_item(
                        text: "Upload from device",
                        icon: "upload",
                        href: "#",
                        data: { action: "recording-studio-attachable--attachment-image-picker#browseUpload" }
                      ) %>

                      <% if cloud_upload_providers.any? %>
                        <% dropdown.menu_divider %>

                        <% cloud_upload_providers.each do |provider| %>
                          <% provider_button_options = provider.button_options(view_context: self, recording: @page_recording) %>
                          <% provider_menu_item_options = {
                            text: provider_button_options[:text],
                            icon: provider_button_options[:icon],
                            href: "#",
                            data: provider_button_options.fetch(:data, {}).merge(action: "recording-studio-attachable--attachment-image-picker#launchProvider")
                          } %>
                          <% dropdown.menu_item(**provider_menu_item_options) %>
                        <% end %>
                      <% end %>
                    <% end %>
                  </div>

                  <div class="w-full lg:w-auto">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
                      <%= render FlatPack::Search::Component.new(
                        input_id: "#{editor_modal_id}-search",
                        name: :picker_search,
                        value: nil,
                        placeholder: "Search",
                        max_width: :lg,
                        aria: { label: "Search images" },
                        data: {
                          recording_studio_attachable__attachment_image_picker_target: "searchInput",
                          action: "input->recording-studio-attachable--attachment-image-picker#searchChanged"
                        }
                      ) %>
                    </div>
                  </div>
                </div>

                <input
                  type="file"
                  accept="image/*"
                  class="hidden"
                  data-recording-studio-attachable--attachment-image-picker-target="fileInput"
                  data-action="change->recording-studio-attachable--attachment-image-picker#uploadSelected">

                <template data-recording-studio-attachable--attachment-image-picker-target="progressTemplate">
                  <%= render FlatPack::Progress::Component.new(value: 0, max: 100, label: "Progress") %>
                </template>

                <p class="hidden text-sm text-(--surface-muted-content-color)" data-recording-studio-attachable--attachment-image-picker-target="status"></p>

                <div class="hidden space-y-3" data-recording-studio-attachable--attachment-image-picker-target="uploadQueue"></div>

                <div class="hidden rounded-xl border border-(--surface-border-color) bg-(--surface-muted-background-color) px-4 py-3" data-recording-studio-attachable--attachment-image-picker-target="selectionActions">
                  <div class="flex items-center justify-between gap-3">
                    <p class="text-sm text-(--surface-content-color)" data-recording-studio-attachable--attachment-image-picker-target="selectionCount">Select one or more images</p>

                    <div class="flex items-center gap-2">
                    <%= render FlatPack::Button::Component.new(
                      text: "Clear",
                      style: :secondary,
                      size: :sm,
                      type: "button",
                      data: { action: "recording-studio-attachable--attachment-image-picker#clearSelection" }
                    ) %>
                    <%= render FlatPack::Button::Component.new(
                      text: "Add selected",
                      style: :primary,
                      size: :sm,
                      type: "button",
                      data: {
                        action: "recording-studio-attachable--attachment-image-picker#confirmSelection",
                        recording_studio_attachable__attachment_image_picker_target: "confirmButton"
                      }
                    ) %>
                    </div>
                  </div>
                </div>

                <div class="min-h-0 flex-1 overflow-y-auto p-1" data-recording-studio-attachable--attachment-image-picker-target="scrollContainer">
                  <div class="grid grid-cols-2 gap-4 lg:grid-cols-4" data-recording-studio-attachable--attachment-image-picker-target="gallery"></div>

                  <div class="hidden rounded-lg border border-dashed border-(--surface-border-color) px-4 py-8 text-center text-sm text-(--surface-muted-content-color)" data-recording-studio-attachable--attachment-image-picker-target="emptyState">
                    No images found for this page yet.
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <%= body_field %>
      <% end %>

      <%= render FlatPack::Modal::Component.new(id: html_preview_modal_id, title: "HTML output", size: :xl, body_height_mode: :fixed, body_height: "28rem") do |modal| %>
        <% modal.body do %>
          <div class="space-y-3">
            <p class="text-sm text-(--surface-muted-content-color)">Current HTML generated by the editor.</p>
            <textarea
              readonly
              class="min-h-88 w-full rounded-md border border-(--surface-border-color) bg-(--surface-background-color) px-(--form-control-padding) py-(--form-control-padding) font-mono text-xs text-(--surface-content-color)"
              data-page-html-preview-target="output"></textarea>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= render FlatPack::Button::Component.new(text: "Save page", style: :primary, size: :md, type: "submit") %>
    </div>
  <% end %>
</div>