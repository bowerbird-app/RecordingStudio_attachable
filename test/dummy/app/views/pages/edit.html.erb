<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <%= render FlatPack::Breadcrumb::Component.new(
    show_back: true,
    back_text: "Back",
    back_icon: "arrow-left",
    back_href: request.referer.presence || root_path,
    items: [{ text: "Home", href: root_path, icon: "home" }]
  ) %>

  <%= render FlatPack::PageTitle::Component.new(
    title: "Edit inline",
    subtitle: "Update page copy and formatted content for the inline recording demo.",
    variant: :h1
  ) %>

  <div class="flex flex-wrap gap-3">
    <%= link_to page_path(@page), class: "inline-flex" do %>
      <%= render FlatPack::Button::Component.new(text: "View", style: :secondary, size: :md) %>
    <% end %>
  </div>

  <%= form_with model: @page, class: "space-y-4" do %>
    <%= render FlatPack::TextInput::Component.new(
      name: "page[title]",
      label: "Page title",
      value: @page.title,
      required: true
    ) %>

    <% editor_modal_id = "page-image-picker-modal-#{@page.id}" %>
    <% html_preview_modal_id = "page-html-preview-modal-#{@page.id}" %>
    <% body_field = capture do %>
      <%= render FlatPack::TextArea::Component.new(
        name: "page[body]",
        label: "Body",
        value: @page.body,
        placeholder: "Write the page content here...",
        rich_text: true,
        rich_text_options: {
          preset: :content,
          addons: [{ name: :attachment_image }, { name: :html_preview }],
          toolbar: [
            "bold",
            "italic",
            "underline",
            "sep1",
            "strike",
            "code",
            "sep2",
            "attachmentImage",
            "htmlPreview",
            "h1",
            "h2",
            "h3",
            "sep3",
            "bulletList",
            "orderedList",
            "sep4",
            "blockquote",
            "sep5",
            "undo",
            "redo"
          ],
          bubble_menu: false,
          floating_menu: false
        },
        required: true
      ) %>
    <% end %>

    <div
      data-controller="page-html-preview"
      data-action="flat-pack:html-preview->page-html-preview#openFromToolbar"
      data-page-html-preview-modal-id-value="<%= html_preview_modal_id %>">
      <% if @page_recording.present? %>
        <div
          data-controller="recording-studio-attachable--attachment-image-picker"
          data-action="flat-pack:attachment-image-picker->recording-studio-attachable--attachment-image-picker#openPickerFromToolbar"
          data-recording-studio-attachable--attachment-image-picker-picker-url-value="<%= @page_attachment_picker_path %>"
          data-recording-studio-attachable--attachment-image-picker-upload-url-value="<%= @page_attachment_create_path %>"
          data-recording-studio-attachable--attachment-image-picker-direct-upload-url-value="<%= main_app.rails_direct_uploads_path %>"
          data-recording-studio-attachable--attachment-image-picker-modal-id-value="<%= editor_modal_id %>">
          <div data-recording-studio-attachable--attachment-image-picker-target="editorHost">
            <%= body_field %>
          </div>

          <%= render FlatPack::Modal::Component.new(id: editor_modal_id, title: "Insert image", size: :xl, body_height_mode: :fixed, body_height: "32rem") do |modal| %>
            <% modal.body do %>
              <div class="space-y-4">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                  <div class="flex flex-wrap items-center gap-3">
                    <%= render FlatPack::Button::Component.new(
                      text: "Upload",
                      style: :primary,
                      size: :md,
                      icon: "upload",
                      type: "button",
                      data: { action: "recording-studio-attachable--attachment-image-picker#browseUpload" }
                    ) %>
                  </div>

                  <div class="w-full lg:w-auto">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
                      <%= render FlatPack::Search::Component.new(
                        input_id: "#{editor_modal_id}-search",
                        name: :picker_search,
                        value: nil,
                        placeholder: "Search",
                        max_width: :lg,
                        aria: { label: "Search images" },
                        data: {
                          recording_studio_attachable__attachment_image_picker_target: "searchInput",
                          action: "input->recording-studio-attachable--attachment-image-picker#searchChanged"
                        }
                      ) %>
                    </div>
                  </div>
                </div>

                <input
                  type="file"
                  accept="image/*"
                  class="hidden"
                  data-recording-studio-attachable--attachment-image-picker-target="fileInput"
                  data-action="change->recording-studio-attachable--attachment-image-picker#uploadSelected">

                <p class="hidden text-sm text-(--surface-muted-content-color)" data-recording-studio-attachable--attachment-image-picker-target="status"></p>

                <div class="max-h-96 overflow-y-auto pr-1" data-recording-studio-attachable--attachment-image-picker-target="scrollContainer">
                  <div class="grid grid-cols-2 gap-4 lg:grid-cols-4" data-recording-studio-attachable--attachment-image-picker-target="gallery"></div>

                  <div class="hidden rounded-lg border border-dashed border-(--surface-border-color) px-4 py-8 text-center text-sm text-(--surface-muted-content-color)" data-recording-studio-attachable--attachment-image-picker-target="emptyState">
                    No images found for this page yet.
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <%= body_field %>
      <% end %>

      <%= render FlatPack::Modal::Component.new(id: html_preview_modal_id, title: "HTML output", size: :xl, body_height_mode: :fixed, body_height: "28rem") do |modal| %>
        <% modal.body do %>
          <div class="space-y-3">
            <p class="text-sm text-(--surface-muted-content-color)">Current HTML generated by the editor.</p>
            <textarea
              readonly
              class="min-h-[22rem] w-full rounded-md border border-(--surface-border-color) bg-(--surface-background-color) px-[var(--form-control-padding)] py-[var(--form-control-padding)] font-mono text-xs text-(--surface-content-color)"
              data-page-html-preview-target="output"></textarea>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= render FlatPack::Button::Component.new(text: "Save page", style: :primary, size: :md, type: "submit") %>
    </div>
  <% end %>
</div>