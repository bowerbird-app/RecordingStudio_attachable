<%= render FlatPack::Card::Component.new(style: :default) do |card| %>
  <% card.body do %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-(--surface-border-color) text-sm">
        <thead>
          <tr class="text-left text-(--surface-muted-content-color)">
            <th class="px-3 py-2">Preview</th>
            <th class="px-3 py-2">Name</th>
            <th class="px-3 py-2">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-(--surface-border-color)">
          <% attachments.each do |attachment_recording| %>
            <% attachment = attachment_recording.recordable %>
            <% file_extension = File.extname(attachment.original_filename.to_s).delete(".").upcase.presence || "FILE" %>
            <% display_content_type = attachment.content_type.to_s.split("/", 2).last.presence || attachment.content_type %>
            <% display_size = number_to_human_size(attachment.byte_size, strip_insignificant_zeros: true).downcase.delete(" ") %>
            <tr>
              <td class="px-3 py-3 text-(--surface-muted-content-color)">
                <%= link_to attachment_path(attachment_recording), class: "inline-flex rounded-lg focus:outline-none focus:ring-2 focus:ring-(--brand-color)", data: { turbo_frame: "_top" } do %>
                  <% preview_path = attachment_preview_path(attachment, :square_small) %>
                  <% if preview_path.present? %>
                    <div class="relative h-12 w-12 overflow-hidden rounded-lg bg-(--surface-muted-background-color)" data-controller="recording-studio-attachable--image-fallback">
                      <%= image_tag preview_path, alt: attachment.name, class: "h-full w-full object-cover", data: { recording_studio_attachable__image_fallback_target: "image", action: "error->recording-studio-attachable--image-fallback#showFallback" } %>
                      <div class="absolute inset-0 hidden items-center justify-center bg-(--surface-background-color)" data-recording-studio-attachable--image-fallback-target="fallback">
                        <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-(--surface-muted-content-color)">IMAGE</span>
                      </div>
                    </div>
                  <% else %>
                    <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-(--surface-background-color) text-(--surface-content-color) shadow-sm ring-1 ring-(--surface-border-color)">
                      <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-(--surface-muted-content-color)"><%= file_extension %></span>
                    </div>
                  <% end %>
                <% end %>
              </td>
              <td class="px-3 py-3">
                <%= render FlatPack::Link::Component.new(
                  href: attachment_path(attachment_recording),
                  class: "font-medium",
                  data: { turbo_frame: "_top" }
                ) do %>
                  <%= attachment.name %>
                <% end %>
                <div class="text-xs text-(--surface-muted-content-color)"><%= display_content_type %> <%= display_size %></div>
              </td>
              <td class="px-3 py-3">
                <div class="flex gap-2">
                  <%= render FlatPack::Tooltip::Component.new(text: "Download") do %>
                    <%= link_to download_attachment_path(attachment_recording), class: "inline-flex", data: { turbo_frame: "_top" } do %>
                      <%= render FlatPack::Button::Component.new(icon: "arrow-down-tray", icon_only: true, style: :ghost, size: :md, aria: { label: "Download attachment" }) %>
                    <% end %>
                  <% end %>
                  <% unless attachment_recording.respond_to?(:trashed_at) && attachment_recording.trashed_at.present? %>
                    <%= render FlatPack::Tooltip::Component.new(text: "Trash") do %>
                      <%= button_to destroy_attachment_path(attachment_recording), method: :delete, class: "inline-flex" do %>
                        <%= render FlatPack::Button::Component.new(icon: "trash", icon_only: true, style: :ghost, size: :md, aria: { label: "Trash attachment" }) %>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>