<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Recording tree",
    subtitle: "All seeded recordings in the dummy app, shown by parent-child structure.",
    variant: :h1
  ) %>

  <% if @root_recordings.any? %>
    <ul class="list-disc space-y-3 pl-6 text-sm text-[var(--surface-content-color)] marker:text-[var(--surface-muted-content-color)]">
      <%= render partial: "recording_node", collection: @root_recordings, as: :recording, locals: { recording_children: @recording_children } %>
    </ul>
  <% else %>
    <p class="text-sm text-[var(--surface-muted-content-color)]">Seed the dummy app to populate the recordings tree.</p>
  <% end %>
</div>