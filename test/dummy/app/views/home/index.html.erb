<div class="mx-auto flex w-full max-w-4xl flex-col gap-8">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Attachment demo",
    subtitle: "Upload images and files",
    variant: :h1
  ) %>

  <% if @root_attachment_upload_path.present? && @root_attachment_listing_path.present? %>
    <div class="flex flex-wrap gap-3">
      <%= link_to @root_attachment_upload_path, class: "inline-flex" do %>
        <%= render FlatPack::Button::Component.new(text: "Add", style: :primary, size: :md) %>
      <% end %>
      <%= link_to @root_attachment_listing_path, class: "inline-flex" do %>
        <%= render FlatPack::Button::Component.new(text: "Library", style: :secondary, size: :md) %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-[var(--surface-muted-content-color)]">Seed the workspace recording to enable the demo links.</p>
  <% end %>

  <section class="space-y-4">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Page attachments",
      subtitle: @page&.title || "Seeded page demo"
    ) %>

    <% if @page_attachment_upload_path.present? && @page_attachment_listing_path.present? %>
      <div class="flex flex-wrap gap-3">
        <%= link_to @page_attachment_upload_path, class: "inline-flex" do %>
          <%= render FlatPack::Button::Component.new(text: "Add", style: :primary, size: :md) %>
        <% end %>
        <%= link_to @page_attachment_listing_path, class: "inline-flex" do %>
          <%= render FlatPack::Button::Component.new(text: "Attachments", style: :secondary, size: :md) %>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-[var(--surface-muted-content-color)]">Seed the page recording to enable the page attachment demo.</p>
    <% end %>
  </section>
</div>
