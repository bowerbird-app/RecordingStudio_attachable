<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <%= render FlatPack::Breadcrumb::Component.new(
    show_back: true,
    back_text: "Back",
    back_icon: "arrow-left",
    back_href: request.referer.presence || root_path,
    items: [{ text: "Home", href: root_path, icon: "home" }]
  ) %>

  <%= render FlatPack::PageTitle::Component.new(
    title: "Edit inline",
    subtitle: "Update page copy and formatted content for the inline recording demo.",
    variant: :h1
  ) %>

  <%= form_with model: @page, class: "space-y-4" do %>
    <%= render FlatPack::TextInput::Component.new(
      name: "page[title]",
      label: "Page title",
      value: @page.title,
      required: true
    ) %>

    <% editor_modal_id = "page-image-picker-modal-#{@page.id}" %>
    <% body_field = capture do %>
      <%= render FlatPack::TextArea::Component.new(
        name: "page[body]",
        label: "Body",
        value: @page.body,
        placeholder: "Write the page content here...",
        rich_text: true,
        rich_text_options: {
          preset: :content,
          toolbar: [
            "bold",
            "italic",
            "underline",
            "sep1",
            "strike",
            "code",
            "sep2",
            "attachmentImage",
            "h1",
            "h2",
            "h3",
            "sep3",
            "bulletList",
            "orderedList",
            "sep4",
            "blockquote",
            "sep5",
            "undo",
            "redo"
          ],
          bubble_menu: false,
          floating_menu: false
        },
        required: true
      ) %>
    <% end %>

    <% if @page_recording.present? %>
      <div
        data-controller="page-inline-image-picker"
        data-action="flat-pack:attachment-image-picker->page-inline-image-picker#openPickerFromToolbar"
        data-page-inline-image-picker-picker-url-value="<%= @page_attachment_picker_path %>"
        data-page-inline-image-picker-upload-url-value="<%= @page_attachment_create_path %>"
        data-page-inline-image-picker-direct-upload-url-value="<%= main_app.rails_direct_uploads_path %>"
        data-page-inline-image-picker-modal-id-value="<%= editor_modal_id %>">
        <div data-page-inline-image-picker-target="editorHost">
          <%= body_field %>
        </div>

        <%= render FlatPack::Modal::Component.new(id: editor_modal_id, title: "Insert image", size: :xl, body_height_mode: :fixed, body_height: "32rem") do |modal| %>
          <% modal.body do %>
            <div class="space-y-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
                <div class="min-w-0 flex-1 space-y-1">
                  <label class="block text-sm font-medium text-(--surface-content-color)" for="<%= editor_modal_id %>-search">Search images</label>
                  <input
                    id="<%= editor_modal_id %>-search"
                    type="search"
                    placeholder="Search by image name"
                    class="flat-pack-input w-full rounded-md border border-(--surface-border-color) bg-(--surface-background-color) px-(--form-control-padding) py-(--form-control-padding) text-sm text-(--surface-content-color) placeholder:text-(--surface-muted-content-color) focus:outline-none focus:ring-2 focus:ring-inset focus:ring-ring"
                    data-page-inline-image-picker-target="searchInput"
                    data-action="input->page-inline-image-picker#searchChanged">
                </div>

                <div class="flex items-center gap-3">
                  <%= render FlatPack::Button::Component.new(
                    text: "Upload image",
                    style: :primary,
                    size: :md,
                    type: "button",
                    data: { action: "page-inline-image-picker#browseUpload" }
                  ) %>
                </div>
              </div>

              <input
                type="file"
                accept="image/*"
                class="hidden"
                data-page-inline-image-picker-target="fileInput"
                data-action="change->page-inline-image-picker#uploadSelected">

              <p class="hidden text-sm text-(--surface-muted-content-color)" data-page-inline-image-picker-target="status"></p>

              <div class="grid grid-cols-2 gap-4 lg:grid-cols-4" data-page-inline-image-picker-target="gallery"></div>

              <div class="hidden rounded-lg border border-dashed border-(--surface-border-color) px-4 py-8 text-center text-sm text-(--surface-muted-content-color)" data-page-inline-image-picker-target="emptyState">
                No images found for this page yet.
              </div>

              <div class="flex items-center justify-between gap-3">
                <button
                  type="button"
                  class="rounded-md border border-(--surface-border-color) px-3 py-2 text-sm text-(--surface-content-color) disabled:cursor-not-allowed disabled:opacity-50"
                  data-page-inline-image-picker-target="previousButton"
                  data-action="page-inline-image-picker#previousPage">
                  Previous
                </button>

                <p class="text-sm text-(--surface-muted-content-color)" data-page-inline-image-picker-target="paginationLabel">Page 1 of 1</p>

                <button
                  type="button"
                  class="rounded-md border border-(--surface-border-color) px-3 py-2 text-sm text-(--surface-content-color) disabled:cursor-not-allowed disabled:opacity-50"
                  data-page-inline-image-picker-target="nextButton"
                  data-action="page-inline-image-picker#nextPage">
                  Next
                </button>
              </div>
            </div>
          <% end %>

          <% modal.footer do %>
            <%= render FlatPack::Button::Component.new(text: "Close", style: :secondary, size: :md, type: "button", data: { action: "flat-pack--modal#close" }) %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= body_field %>
    <% end %>

    <div class="flex flex-wrap gap-3">
      <%= render FlatPack::Button::Component.new(text: "Save page", style: :primary, size: :md, type: "submit") %>
    </div>
  <% end %>
</div>