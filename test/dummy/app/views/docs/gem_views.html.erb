<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Gem views",
    subtitle: "The user-facing templates the gem currently provides out of the box.",
    variant: :h1
  ) %>

  <%= render FlatPack::List::Component.new(divider: true, class: "rounded-xl border border-[var(--surface-border-color)] bg-[var(--surface-background-color)] p-4") do %>
    <% @gem_views.each do |view| %>
      <%= render FlatPack::List::Item.new(icon: view[:icon]) do %>
        <div class="space-y-1">
          <p class="text-sm font-semibold text-[var(--surface-content-color)]"><%= view[:title] %></p>
          <p class="text-sm text-[var(--surface-muted-content-color)]"><%= view[:description] %></p>
          <p class="font-mono text-xs text-[var(--surface-muted-content-color)]"><%= view[:path] %></p>
          <p class="text-xs text-[var(--surface-muted-content-color)]"><%= view[:example] %></p>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
